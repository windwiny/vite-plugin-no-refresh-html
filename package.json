{
  "name": "vite-plugin-no-refresh-html",
  "version": "1.0.4",
  "description": "Vite plugin that hot-updates JS files without refreshing the HTML page, preserving user inputs",
  "type": "module",
  "main": "vite-plugin-no-refresh-html.js",
  "exports": {
    ".": {
      "import": "./vite-plugin-no-refresh-html.js",
      "require": "./vite-plugin-no-refresh-html.js"
    }
  },
  "files": [
    "README.md",
    "README_zh.md",
    "public/toast.js",
    "public/toast.css",
    "vite-plugin-no-refresh-html.js"
  ],
  "scripts": {
    "prepublishOnly": "npm run test",
    "lint": "eslint . --ext .js,.mjs",
    "test": "node --test",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "publish:latest": "npm publish --access public",
    "publish:next": "npm publish --tag next --access public"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "vite",
    "vite-plugin",
    "hmr javascript",
    "no refresh html",
    "preserve input",
    "script nomodule"
  ],
  "author": "windwiny",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/windwiny/vite-plugin-no-refresh-html.git"
  },
  "bugs": {
    "url": "https://github.com/windwiny/vite-plugin-no-refresh-html/issues"
  },
  "homepage": "https://github.com/windwiny/vite-plugin-no-refresh-html#readme",
  "peerDependencies": {
    "vite": "^8.0.1"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    }
  }
}
